# PostgreSQL Configuration
POSTGRES_DB=payment_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password_123

# Spring Boot Application Configuration
SPRING_PROFILES_ACTIVE=prod
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/payment_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres_password_123
SPRING_DATASOURCE_HIKARI_MAXIMUM_POOL_SIZE=20
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_DATABASE_PLATFORM=org.hibernate.dialect.PostgreSQLDialect
SPRING_FLYWAY_ENABLED=true

# Server Configuration
SERVER_PORT=8080

# Logging Configuration
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_WRAITH=DEBUG

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@payment.local
PGADMIN_DEFAULT_PASSWORD=admin_password_123

# Application
APP_PORT=8080
DB_PORT=5432
PGADMIN_PORT=5050

